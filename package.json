{
  "name": "veniceai-cli",
  "version": "2.0.0",
  "description": "Privacy-first command line interface for Venice AI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "venice": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "lint": "eslint \"src/**/*.ts\"",
    "clean": "node -e \"const fs = require('fs'); fs.rmSync('dist', { recursive: true, force: true });\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@noble/ciphers": "^1.0.0",
    "@noble/hashes": "^1.6.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "elliptic": "^6.6.1",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/elliptic": "^6.4.18",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "venice",
    "ai",
    "cli",
    "llm",
    "openai",
    "chat",
    "image-generation",
    "text-to-speech",
    "transcription",
    "privacy"
  ],
  "author": "Venice AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/veniceai/venice-cli"
  },
  "bugs": {
    "url": "https://github.com/veniceai/venice-cli/issues"
  },
  "homepage": "https://venice.ai"
}
